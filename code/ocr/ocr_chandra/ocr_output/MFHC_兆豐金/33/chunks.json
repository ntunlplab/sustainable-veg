    "content": "<table><thead><tr><th>類別</th><th>項目</th><th>銀行</th><th>證券</th><th>票券</th><th>保險</th><th>合計</th></tr></thead><tbody><tr><td rowspan=\"2\">綠色債券</td><td>件數</td><td>29</td><td>6</td><td>10</td><td>2</td><td>47</td></tr><tr><td>年底投資餘額</td><td>75.3</td><td>10</td><td>30.2</td><td>1.4</td><td>116.9</td></tr><tr><td rowspan=\"2\">社會責任債券</td><td>件數</td><td>11</td><td>3</td><td>-</td><td>-</td><td>14</td></tr><tr><td>年底投資餘額</td><td>27.9</td><td>3</td><td>-</td><td>-</td><td>30.9</td></tr><tr><td rowspan=\"2\">可持續發展債券</td><td>件數</td><td>6</td><td>5</td><td>5</td><td>1</td><td>17</td></tr><tr><td>年底投資餘額</td><td>16</td><td>9</td><td>15.3</td><td>0.5</td><td>40.8</td></tr><tr><td rowspan=\"2\">可持續發展連結債券</td><td>件數</td><td>22</td><td>-</td><td>-</td><td>-</td><td>22</td></tr><tr><td>年底投資餘額</td><td>33.1</td><td>-</td><td>-</td><td>-</td><td>33.1</td></tr></tbody></table>",
