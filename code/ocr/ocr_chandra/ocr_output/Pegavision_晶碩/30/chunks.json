    ],
    "label": "Section-Header",
    "content": "<h4>3.3.1 晶碩價值鏈中的衝擊管理</h4>",
    "bbox_pdf": [
      630.3276,
      372.1716,
      807.876,
      387.6804
    ]
  },
  {
    "bbox": [
      2235.48,
