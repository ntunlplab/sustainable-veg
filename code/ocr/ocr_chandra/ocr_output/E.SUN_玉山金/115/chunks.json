      169.4196
    ]
  },
  {
    "bbox": [
      260.4,
      484.32,
      776.62,
      513.26
    ],
    "label": "Text",
    "content": "<p>(1) 原始目的與二次使用目的關聯性須合理。</p>",
    "bbox_pdf": [
      93.744,
      174.3552,
      279.5832,
      184.7736
    ]
  },
  {
    "bbox": [
      260.4,
      522.4,
      799.46,
      551.33
    ],
    "label": "Text",
    "content": "<p>(2) 顧客之身分、背景是否適宜進行二次使用。</p>",
