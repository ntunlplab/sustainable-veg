    "label": "Table",
    "content": "<table><thead><tr><th>年度</th><th>2018</th><th>2019</th><th>2020</th><th>2021</th><th>2022</th></tr></thead><tbody><tr><td>定檢率</td><td>92.5%</td><td>92.8%</td><td>92.5%</td><td>86.5%</td><td>84.9%</td></tr></tbody></table>",
    "bbox_pdf": [
