    {
      "id": 2,
      "text": "<table><tr><th>策略</th><th>2022年達成績效</th><th>2022年短期目標</th><th>達標與否</th><th>2023年預期目標</th><th>長期目標</th></tr><tr><td>提升顧客整體滿意度</td><td>回收有效問卷滿意度達92%</td><td>滿意度≥97%</td><td>否</td><td>非常滿意度≥93%</td><td>逐年成長</td></tr></table>",
      "bbox": [
